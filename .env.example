# Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY

# Resend (correos transaccionales) — se agrega en Fase 5
RESEND_API_KEY=

# Secret para el Vercel Cron (genera uno con: openssl rand -hex 32)
CRON_SECRET=

# Telegram (notificaciones internas de registro/KYC) — solo servidor, NUNCA usar prefijo NEXT_PUBLIC_
# Token: hablar con @BotFather. Chat ID: enviar un mensaje al bot y consultar
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Bold (pagos: suscripción y paquetes de tokens) — solo servidor
BOLD_SECRET_KEY=
BOLD_WEBHOOK_SECRET=
